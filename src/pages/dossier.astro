---
// src/pages/index.astro
// CRISPR Dossier Clínico — Clasificado REF_DOC_401
import DossierContent from '../components/DossierContent';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>REF_DOC_401 — Dossier Clínico: CRISPR-Cas9</title>
    <meta name="description" content="Archivo clasificado. Investigación CRISPR-Cas9. UTCH Unidad BIS." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;700&family=Geist:wght@400;500;900&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      /* ─── Reset ─────────────────────────────────────────────────────────────── */
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      ::selection { background: #FF003C; color: #000; }

      :root {
        --red: #FF003C;
        --white: #FFFFFF;
        --mono: 'JetBrains Mono', monospace;
        --display: 'Geist', 'Inter', sans-serif;
      }

      html {
        background: #000000;
        color: #FFFFFF;
        font-family: var(--display);
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        scroll-behavior: smooth;
      }

      body {
        background: #000000;
        min-height: 100vh;
        overflow-x: hidden;
        position: relative;
      }

      /* CSS Noise Grain */
      body::before {
        content: '';
        position: fixed;
        inset: 0;
        z-index: 9999;
        pointer-events: none;
        opacity: 0.028;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
        background-size: 200px 200px;
        animation: grain 0.4s steps(2) infinite;
      }
      @keyframes grain {
        0%   { transform: translate(0,0) }
        25%  { transform: translate(-2%,-3%) }
        50%  { transform: translate(3%,2%) }
        75%  { transform: translate(-1%,4%) }
        100% { transform: translate(1%,-1%) }
      }

      /* ─── Decrypt Overlay ─────────────────────────────────────────────────── */
      .decrypt-overlay {
        position: fixed;
        inset: 0;
        z-index: 1000;
        background: #000;
        display: flex;
        align-items: flex-end;
        padding: clamp(2rem,5vw,5rem);
        will-change: transform;
        overflow: hidden;
      }
      .decrypt-inner { width: 100%; max-width: 640px; }
      .decrypt-header {
        display: flex;
        justify-content: space-between;
        margin-bottom: 2rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid #111;
      }
      .decrypt-lines { display: flex; flex-direction: column; gap: 0.5rem; }
      .decrypt-line {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-family: var(--mono);
        font-size: clamp(9px,1.2vw,11px);
        color: #f5f5f5;
        letter-spacing: 0.1em;
        text-transform: uppercase;
      }
      .decrypt-line.done { color: #fff; }
      .decrypt-prompt { color: #f5f5f5; flex-shrink: 0; }
      .decrypt-cursor {
        display: inline-block;
        color: #fff;
        margin-left: 4px;
        animation: blink 0.7s step-end infinite;
      }
      @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }
      .decrypt-granted {
        margin-top: 2rem;
        font-family: var(--mono);
        font-size: clamp(10px,1.4vw,13px);
        color: #fff;
        letter-spacing: 0.22em;
        text-transform: uppercase;
      }

      /* ─── Dossier Root ────────────────────────────────────────────────────── */
      .dossier-root {
        max-width: 1440px;
        margin: 0 auto;
        border-left: 1px solid rgba(255,255,255,0.05);
        border-right: 1px solid rgba(255,255,255,0.05);
        min-height: 100vh;
      }

      /* ─── Ticker ──────────────────────────────────────────────────────────── */
      .ticker-wrap {
        overflow: hidden;
        border-bottom: 1px solid rgba(255,255,255,0.05);
        padding: 0.55rem 0;
        white-space: nowrap;
        background: rgba(255,255,255,0.01);
      }
      .ticker-track {
        display: inline-flex;
        animation: ticker 42s linear infinite;
      }
      .ticker-track span {
        font-family: var(--mono);
        font-size: 9px;
        color: #d4d4d4;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        padding-right: 5rem;
      }
      @keyframes ticker { from{transform:translateX(0)} to{transform:translateX(-50%)} }

      /* ─── Header ──────────────────────────────────────────────────────────── */
      .dossier-header {
        padding: clamp(3rem,6vw,6rem) clamp(1.5rem,5vw,5rem) clamp(3rem,5vw,5rem);
        border-bottom: 1px solid rgba(255,255,255,0.05);
        will-change: transform, opacity;
      }
      .header-meta {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: clamp(3rem,5vw,5rem);
        flex-wrap: wrap;
        gap: 1rem;
      }
      .header-ref { display: flex; align-items: center; gap: 0.75rem; }
      .mono-xs {
        font-family: var(--mono);
        font-size: 9px;
        letter-spacing: 0.16em;
        text-transform: uppercase;
      }
      .text-zinc-600 { color: #52525b; }
      .text-zinc-700 { color: #3f3f46; }
      .text-zinc-800 { color: #27272a; }
      .status-pill {
        font-family: var(--mono);
        font-size: 9px;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: #e5e5e5;
        border: 1px solid rgba(255,255,255,0.06);
        padding: 0.35rem 0.75rem;
      }
      .header-eyebrow {
        font-family: var(--mono);
        font-size: clamp(9px,1.1vw,11px);
        color: #a1a1a1;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        margin-bottom: 1.25rem;
      }
      .header-h1 {
        font-family: var(--display);
        font-weight: 900;
        font-size: clamp(4rem,13vw,13rem);
        line-height: 0.88;
        letter-spacing: -0.04em;
        color: #fff;
        text-transform: uppercase;
        margin-bottom: 2.5rem;
      }
      .h1-cas {
        color: transparent;
        -webkit-text-stroke: 1px rgba(255,255,255,0.70);
        display: block;
        font-style: italic;
      }
      .header-sub {
        font-family: var(--mono);
        font-size: clamp(9px,1.1vw,11px);
        color: #e5e5e5;
        letter-spacing: 0.06em;
        line-height: 1.9;
        max-width: 580px;
      }

      /* Stats */
      .stats-row {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        border: 1px solid rgba(255,255,255,0.06);
        margin-top: clamp(2rem,4vw,4rem);
      }
      @media (max-width: 640px) {
        .stats-row { grid-template-columns: repeat(2,1fr); }
      }
      .stat-block {
        padding: clamp(1.25rem,2.5vw,2.5rem) clamp(1.5rem,3vw,3rem);
        border-right: 1px solid rgba(255,255,255,0.06);
      }
      .stat-block:last-child { border-right: none; }
      .stat-value {
        font-family: var(--display);
        font-weight: 900;
        font-size: clamp(2rem,4vw,4rem);
        line-height: 1;
        color: #fff;
        letter-spacing: -0.03em;
        margin-bottom: 0.5rem;
      }
      .stat-label {
        font-family: var(--mono);
        font-size: 8px;
        color: #b2b2b2;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        line-height: 1.6;
      }

      /* ─── Section Divider ─────────────────────────────────────────────────── */
      .section-divider {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        padding: clamp(2rem,4vw,4rem) clamp(1.5rem,5vw,5rem) 0;
      }
      .divider-line {
        flex: 1;
        height: 1px;
        background: rgba(255,255,255,0.05);
      }

      /* ─── Archives ────────────────────────────────────────────────────────── */
      .archives-section {
        padding: 0 clamp(1.5rem,5vw,5rem);
        margin-top: 2rem;
      }
      .archives-header-row {
        display: grid;
        grid-template-columns: 180px 1fr 160px;
        padding: 0.75rem 1.25rem;
        border-bottom: 1px solid rgba(255,255,255,0.05);
        gap: 1.5rem;
      }
      @media (max-width: 768px) { .archives-header-row { display: none; } }
      .col-label {
        font-family: var(--mono);
        font-size: 9px;
        color: #fff;
        letter-spacing: 0.15em;
        text-transform: uppercase;
      }

      /* Archive Row */
      .archive-row {
        display: grid;
        grid-template-columns: 180px 1fr 160px;
        gap: 1.5rem;
        padding: clamp(1.25rem,2.5vw,2rem) 1.25rem;
        border-bottom: 1px solid rgba(255,255,255,0.04);
        position: relative;
        cursor: default;
        align-items: start;
        overflow: hidden;
        transition: border-color 0.25s;
      }
      @media (max-width: 768px) {
        .archive-row { grid-template-columns: 1fr; gap: 1rem; }
      }
      .archive-row.hov { border-color: rgba(255,255,255,0.1); }
      .archive-row > * { position: relative; z-index: 1; }

      /* Hover fill animation handled by Framer Motion .archive-hover-fill div */
      .archive-hover-fill {
        position: absolute;
        inset: 0;
        background: #fff;
        z-index: 0;
        transform-origin: left;
        pointer-events: none;
      }

      /* Text inversions on hover */
      .archive-row.hov .archive-num,
      .archive-row.hov .archive-tag,
      .archive-row.hov .archive-authors,
      .archive-row.hov .archive-title,
      .archive-row.hov .archive-desc,
      .archive-row.hov .archive-meta { color: #000 !important; }
      .archive-row.hov .badge-classif { color: #000 !important; border-color: rgba(0,0,0,0.15) !important; }
      .archive-row.hov .meta-sep { color: #999 !important; }

      .archive-id-col { display: flex; flex-direction: column; gap: 0.5rem; }
      .archive-num {
        font-family: var(--display);
        font-weight: 900;
        font-size: clamp(2rem,3.5vw,3.5rem);
        line-height: 1;
        color: rgb(255, 255, 255);
        letter-spacing: -0.04em;
        transition: color 0.02s;
      }
      .archive-tag {
        font-family: var(--mono);
        font-size: 8px;
        color: #fff;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        transition: color 0.02s;
      }
      .archive-content { display: flex; flex-direction: column; gap: 0.55rem; }
      .archive-authors {
        font-family: var(--mono);
        font-size: 9px;
        color: #d4d4d4;
        letter-spacing: 0.07em;
        transition: color 0.02s;
      }
      .archive-title {
        font-family: var(--display);
        font-weight: 900;
        font-size: clamp(0.85rem,1.5vw,1.05rem);
        color: #fff;
        letter-spacing: -0.01em;
        line-height: 1.25;
        transition: color 0.02s;
      }
      .archive-desc {
        font-family: var(--mono);
        font-size: clamp(9px,0.9vw,10px);
        color: #52525b;
        line-height: 1.75;
        letter-spacing: 0.03em;
        transition: color 0.02s;
      }
      .archive-meta {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        font-family: var(--mono);
        font-size: 8px;
        color: #e5e5e5;
        letter-spacing: 0.08em;
        margin-top: 0.25rem;
        transition: color 0.02s;
      }
      .meta-sep { color: #1a1a1a; transition: color 0.02s; }
      .archive-badges {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        align-items: flex-end;
      }
      @media (max-width: 768px) {
        .archive-badges { align-items: flex-start; flex-direction: row; flex-wrap: wrap; }
      }
      .badge-classif {
        font-family: var(--mono);
        font-size: 8px;
        color: rgba(255,255,255,0.25);
        letter-spacing: 0.15em;
        text-transform: uppercase;
        border: 1px solid rgba(255,255,255,0.07);
        padding: 0.25rem 0.5rem;
        transition: color 0.02s, border-color 0.02s;
      }
      .badge-risk {
        font-family: var(--mono);
        font-size: 8px;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        border: 1px solid;
        padding: 0.25rem 0.5rem;
        transition: color 0.1s, border-color 0.1s;
      }

      /* ─── Team ────────────────────────────────────────────────────────────── */
      .team-section {
        padding: clamp(3rem,5vw,5rem) clamp(1.5rem,5vw,5rem);
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: clamp(3rem,6vw,6rem);
        border-top: 1px solid rgba(255,255,255,0.05);
      }
      @media (max-width: 900px) { .team-section { grid-template-columns: 1fr; } }
      .team-institution {
        display: flex;
        flex-direction: column;
        gap: 2rem;
        border-right: 1px solid rgba(255,255,255,0.05);
        padding-right: clamp(2rem,4vw,4rem);
      }
      @media (max-width: 900px) {
        .team-institution {
          border-right: none;
          border-bottom: 1px solid rgba(255,255,255,0.05);
          padding-right: 0;
          padding-bottom: 2rem;
        }
      }
      .seal-ring {
        width: 80px; height: 80px;
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        position: relative;
      }
      .seal-ring::before {
        content: '';
        position: absolute;
        inset: 6px;
        border: 1px solid rgba(255,255,255,0.04);
        border-radius: 50%;
      }
      .seal-text {
        font-family: var(--display);
        font-weight: 900;
        font-size: 18px;
        color: rgba(255,255,255,0.35);
        letter-spacing: 0.05em;
      }
      .institution-name {
        font-family: var(--display);
        font-weight: 900;
        font-size: clamp(1.1rem,2vw,1.6rem);
        color: #fff;
        letter-spacing: -0.02em;
        line-height: 1.2;
        margin-bottom: 0.4rem;
      }
      .institution-unit {
        font-family: var(--mono);
        font-size: 10px;
        color: #e5e5e5;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }
      .team-grid { display: flex; flex-direction: column; }
      .team-node {
        padding: clamp(1.25rem,2.5vw,2rem) 0;
        border-bottom: 1px solid rgba(255,255,255,0.04);
        display: grid;
        grid-template-columns: 80px 1fr;
        gap: 0.4rem 2rem;
        align-items: start;
        transition: border-color 0.2s;
      }
      .team-node:hover { border-color: rgba(255,255,255,0.1); }
      .team-node:last-child { border-bottom: none; }
      .team-node-id {
        grid-row: 1 / 3;
        font-family: var(--mono);
        font-size: 9px;
        color: #9b9b9e;
        letter-spacing: 0.1em;
        padding-top: 0.15rem;
      }
      .team-node-name {
        font-family: var(--display);
        font-weight: 900;
        font-size: clamp(0.95rem,1.5vw,1.15rem);
        color: #fff;
        letter-spacing: -0.01em;
        line-height: 1.2;
      }
      .team-node-role {
        font-family: var(--mono);
        font-size: 9px;
        color: #e5e5e5;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }
      .team-node-clearance {
        grid-column: 1 / -1;
        font-family: var(--mono);
        font-size: 8px;
        color: #1a1a1a;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        margin-top: 0.4rem;
        border-top: 1px solid rgba(255,255,255,0.03);
        padding-top: 0.45rem;
        transition: color 0.2s;
      }
      .team-node:hover .team-node-clearance { color: #27272a; }

      /* ─── Footer ──────────────────────────────────────────────────────────── */
      .dossier-footer {
        border-top: 1px solid rgba(255,255,255,0.05);
        padding: clamp(2rem,4vw,4rem) clamp(1.5rem,5vw,5rem);
        display: flex;
        flex-direction: column;
        gap: 2rem;
      }
      .footer-barcode { overflow: hidden; opacity: 0.5; }
      .footer-meta {
        display: flex;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
        border-top: 1px solid rgba(255,255,255,0.04);
        padding-top: 1.5rem;
      }

      .w-12 {
        width: 12rem;
      }

      .h-12 {
        height: 12rem;
      }

      /* ─── Scrollbar ───────────────────────────────────────────────────────── */
      ::-webkit-scrollbar { width: 3px; }
      ::-webkit-scrollbar-track { background: #000; }
      ::-webkit-scrollbar-thumb { background: #1a1a1a; }
      ::-webkit-scrollbar-thumb:hover { background: var(--red); }
    </style>
  </head>
  <body>
    <DossierContent client:only="react" />
  </body>
</html>